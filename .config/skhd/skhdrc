# Yabai

ctrl + fn - p : yabai -m space --layout stack
ctrl + fn - b : yabai -m space --layout bsp


### Stop/start/restart yabai

ctrl + alt - r : yabai --restart-service
ctrl + alt - q : yabai --stop-service
ctrl + alt - s : yabai --start-service
ctrl + alt - n : yabai -m window --insert stack

### Focus within space

alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

### Focus between displays

alt - w: yabai -m display --focus west
alt - e: yabai -m display --focus east
alt - n: yabai -m display --focus north
alt - s: yabai -m display --focus south

### Rotate layout clockwise

# alt + shift - r : yabai -m space --balance && yabai -m space --rotate 90

### Toggle window float

alt + shift - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

### Maximize a window(works when tiled, not floating)

alt + shift - m : yabai -m window --toggle zoom-fullscreen

### Resize windows evenly within space

alt + shift - e : yabai -m space --balance

### Swap Windows

alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - h : yabai -m window --swap west
alt + shift - l : yabai -m window --swap east

### Grow/Shrink Window

ctrl + cmd - j : yabai -m window north --resize bottom:0:40 2> /dev/null || yabai -m window --resize bottom:0:40
ctrl + cmd - k : yabai -m window south --resize top:0:-40 2> /dev/null || yabai -m window --resize top:0:-40
ctrl + cmd - h : yabai -m window west --resize right:-40:0 2> /dev/null || yabai -m window --resize right:-40:0
ctrl + cmd - l : yabai -m window east --resize left:40:0 2> /dev/null || yabai -m window --resize left:40:0

### Move window to prev and next space

alt + shift - p : yabai -m window --space prev;
alt + shift - n : yabai -m window --space next;

### Move window to space

alt + shift - 1 : yabai -m window --space 1;
alt + shift - 2 : yabai -m window --space 2;
alt + shift - 3 : yabai -m window --space 3;
alt + shift - 4 : yabai -m window --space 4;
alt + shift - 5 : yabai -m window --space 5;
alt + shift - 6 : yabai -m window --space 6;
alt + shift - 7 : yabai -m window --space 7;

### Unsure

## This one never works

### flip along y-axis

alt + shift - y : yabai -m space --mirror y-axis

### This one sometimes works

## flip along x-axis

alt + shift - x : yabai -m space --mirror x-axis

## Move window to display left and right

alt + shift - s : yabai -m window --display west; yabai -m display --focus west;
alt + shift - g : yabai -m window --display east; yabai -m display --focus east;

## Move window and split

ctrl + alt - j : yabai -m window --warp south
ctrl + alt - k : yabai -m window --warp north
ctrl + alt - h : yabai -m window --warp west
ctrl + alt - l : yabai -m window --warp east

# Resize

alt + shift + ctrl + cmd - j : yabai -m window north --resize bottom:0:40 2> /dev/null || yabai -m window --resize bottom:0:40
alt + shift + ctrl + cmd - k : yabai -m window south --resize top:0:-40 2> /dev/null || yabai -m window --resize top:0:-40
alt + shift + ctrl + cmd - h : yabai -m window west --resize right:-40:0 2> /dev/null || yabai -m window --resize right:-40:0
alt + shift + ctrl + cmd - l : yabai -m window east --resize left:40:0 2> /dev/null || yabai -m window --resize left:40:0


### Toggle Window Height in Column

alt + shift - z : yabai -m window --toggle zoom-parent

# Full

alt + shift + ctrl + cmd - i: yabai -m window --toggle zoom-parent

# Full window

alt + shift + ctrl + cmd - u: yabai -m window --toggle zoom-fullscreen

# Maximize window(pressing the green full screen)

alt + shift + ctrl + cmd - y: yabai -m window --toggle native-fullscreen

# If shortcuts aren't working, sometimes need to restart Hyperkey

# General

# move spaces + follow
# ctrl + cmd + alt - right : yabai -m window --space next --focus
# ctrl + cmd + alt - left  : yabai -m window --space prev --focus

# Insert

cmd + ctrl + alt - j  : yabai -m window --insert south
cmd + ctrl + alt - k  : yabai -m window --insert north
cmd + ctrl + alt - h  : yabai -m window --insert west
cmd + ctrl + alt - l  : yabai -m window --insert east

# Disable Cmd + H
cmd - h : true
